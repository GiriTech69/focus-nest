# Node modules installed by Bun, npm, yarn, or pnpm
node_modules/

# Bun lockfile
bun.lockb

# Build output folders
dist/
out/
.plasmo/               # Plasmo extension build output
build/                 # Common build folder (if used)

# TypeScript build info files
*.tsbuildinfo

# Log files
logs/
*.log
report.[0-9]*.json

# Coverage reports
coverage/
*.lcov

# Environment variables files
.env
.env.*.local
.env.local

# Prisma generated client (adjust if your generated client folder is different)
prisma/generated/

# VSCode workspace settings
.vscode/

# IDE directories and files
.idea/
*.sublime-workspace
*.sublime-project

# macOS Finder files
.DS_Store

# Windows thumbnail cache
Thumbs.db

# npm and yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor temp and backup files
*~
*.swp
*.bak
